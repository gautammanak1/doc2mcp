{
  "name": "doc2mcp",
  "version": "0.1.13",
  "description": "Generate documentation MCP servers from your terminal",
  "type": "module",
  "bin": {
    "doc2mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "documentation",
    "cli",
    "cursor",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
