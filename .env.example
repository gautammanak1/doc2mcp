AUTH_SECRET=****

# ASI1 — server-side only (crawl + analysis). NOT in Cursor MCP.
ASI_ONE_API_KEY=****
# Optional: pick another ASI1 model (asi1 default — rate-limit friendly)
# ASI1_MODEL=asi1
# Optional: override the ASI1 image model used by /api/image/generate
# ASI1_IMAGE_MODEL=asi1

# Optional: deliver /api/contact submissions via Resend. When unset, the
# message is still accepted and written to server logs.
# RESEND_API_KEY=re_********
# RESEND_FROM="doc2mcp contact <onboarding@resend.dev>"
# CONTACT_INBOX=doc2mcp@gmail.com

# Public URL for the generated MCP endpoint (Cursor connects here).
# Local dev: http://localhost:3000  |  Production: your deployed URL.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Auth.js base URL — set to the same value as NEXT_PUBLIC_APP_URL in production.
AUTH_URL=https://your-app.vercel.app

# Supabase — replaces Vercel Blob + Redis
NEXT_PUBLIC_SUPABASE_URL=https://ilibxowyivxhdujeguaw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=****
SUPABASE_SERVICE_ROLE_KEY=****

# Supabase Postgres — use Session pooler (port 6543) on Vercel, NOT direct :5432.
# Dashboard → Database → Connection string → Session pooler → URI
POSTGRES_URL=postgresql://postgres.ilibxowyivxhdujeguaw:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# Optional override if Supabase assigns a different pooler host
# SUPABASE_POOLER_HOST=aws-1-ap-south-1.pooler.supabase.com

# Admin dashboard access (defaults to doc2mcp@gmail.com)
ADMIN_EMAIL=doc2mcp@gmail.com

# ---------------------------------------------------------------------------
# Configure ONE; doc2mcp picks the first one that has a key.
# Used as a fallback when crawl is thin and to enrich ask_documentation.
# ---------------------------------------------------------------------------
# Tavily (recommended for docs): https://app.tavily.com
TAVILY_API_KEY=
# Serper (Google SERPs): https://serper.dev
SERPER_API_KEY=
# Brave Search: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=
# Exa (semantic web): https://exa.ai
EXA_API_KEY=

# ---------------------------------------------------------------------------
# Optional crawl-helper APIs (used when docs are JS-rendered SPA shells)
# ---------------------------------------------------------------------------
# Firecrawl: https://firecrawl.dev
FIRECRAWL_API_KEY=
# Jina Reader (free tier): https://r.jina.ai
JINA_API_KEY=
# ScrapingBee: https://scrapingbee.com
SCRAPINGBEE_API_KEY=

# ---------------------------------------------------------------------------
# Billing (Razorpay Standard Checkout) — required for paid plans
# Get keys at https://dashboard.razorpay.com/app/keys
# KEY_ID is exposed to the browser; KEY_SECRET must stay server-side only.
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
