AUTH_SECRET=****

# ASI1 — server-side only (crawl + analysis). NOT in Cursor MCP.
ASI_ONE_API_KEY=****
# Optional: pick another ASI1 model (asi1 default — rate-limit friendly)
# ASI1_MODEL=asi1
# Optional: override the ASI1 image model used by /api/image/generate
# ASI1_IMAGE_MODEL=asi1

# Optional but recommended: deliver /api/contact submissions via Resend.
# Contact messages are always stored in Postgres ContactMessage first; when
# Resend is unset, deliveryStatus becomes "not_configured" and you can still
# read the full message from the database.
# RESEND_API_KEY=re_********
# RESEND_FROM="doc2mcp contact <onboarding@resend.dev>"
# CONTACT_INBOX=doc2mcp@gmail.com

# Public URL for the generated MCP endpoint (Cursor connects here).
# Local dev: http://localhost:3000  |  Production: your deployed URL.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Auth.js base URL — set to the same value as NEXT_PUBLIC_APP_URL in production.
AUTH_URL=https://your-app.vercel.app

# Supabase — replaces Vercel Blob + Redis
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=****
SUPABASE_SERVICE_ROLE_KEY=****

# Supabase Postgres — use Session pooler (port 6543) on Vercel, NOT direct :5432.
# Dashboard → Database → Connection string → Session pooler → URI
POSTGRES_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-YOUR_REGION.pooler.supabase.com:6543/postgres
# Optional override if Supabase assigns a different pooler host
# SUPABASE_POOLER_HOST=aws-1-YOUR_REGION.pooler.supabase.com

# Upstash Redis — caching + rate limiting (free tier 10k commands/day).
#
# Easiest setup: connect via the Vercel ↔ Upstash marketplace integration at
# https://vercel.com/integrations/upstash. That integration auto-injects
# KV_REST_API_URL and KV_REST_API_TOKEN (Vercel KV legacy naming) into
# every environment. lib/redis/upstash.ts reads both the UPSTASH_* and KV_*
# variants, so you do NOT have to rename anything manually.
#
# For local dev, copy the REST URL + token from the Upstash console and
# set EITHER pair below. Tokens are sensitive — never commit real values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# Upstash QStash — REQUIRED in production on the Vercel Hobby plan.
#
# Why: /api/convert + /api/projects/:id/sync schedule the doc-to-MCP
# pipeline (crawl → ASI1 analyze → tool compress → DB writes), which
# routinely takes 40-90s. Vercel Hobby caps every lambda at 60s INCLUDING
# work scheduled via next/server `after()`. Without QStash, the pipeline
# gets killed mid-run and projects get stuck in "crawling"/"analyzing".
#
# With QStash configured, the user-facing route returns instantly after
# enqueuing a job, and QStash POSTs the payload to
# /api/internal/pipeline-worker (signed) so the pipeline runs in its own
# fresh 60s lambda — see lib/queue/qstash.ts.
#
# Get the three values below from https://console.upstash.com/qstash
# (the free tier covers 500 messages/day, way more than doc2mcp needs).
# ---------------------------------------------------------------------------
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Optional: only set if you self-host QStash. Default is the SaaS endpoint.
# QSTASH_URL=https://qstash.upstash.io

# Admin dashboard access (defaults to doc2mcp@gmail.com)
ADMIN_EMAIL=doc2mcp@gmail.com

# ---------------------------------------------------------------------------
# Web search providers — REQUIRED. doc2mcp uses these whenever a crawl is
# thin, when ask_documentation needs to enrich a sparse answer, or when the
# agent is reasoning about a URL outside the crawled corpus. Without at
# least one of TAVILY/SERPER/BRAVE/EXA set, the search fallback is dead and
# any "search the web" tool call returns an empty result.
#
# Behaviour (see lib/search/providers.ts): the first provider whose key is
# set wins. Set all four for redundancy across rate-limit / quota outages.
# Recommended primary: Tavily (best docs coverage at the free tier).
# ---------------------------------------------------------------------------
# Tavily (recommended primary): https://app.tavily.com
TAVILY_API_KEY=
# Serper (Google SERPs): https://serper.dev
SERPER_API_KEY=
# Brave Search: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=
# Exa (semantic web): https://exa.ai
EXA_API_KEY=

# ---------------------------------------------------------------------------
# Crawl-helper APIs — ACTIVE in production.
#
# JINA_API_KEY: doc2mcp falls back to Jina Reader (https://r.jina.ai) for
#   any JS-heavy SPA where the markdown fetcher returns < 80 chars. The
#   free tier works WITHOUT a key, but unauth requests get rate-limited
#   hard on production traffic. Set a key in production — it is effectively
#   required at scale, even though the code will "work" without it.
#
# FIRECRAWL_API_KEY: used by the SPA-shell crawl helper to fetch rendered
#   HTML when both markdown and Jina paths fail. Required in production if
#   you support React/Vue/Astro docs.
#
# SCRAPINGBEE_API_KEY: alternative renderer to Firecrawl. Set either one;
#   if both are set, Firecrawl wins.
# ---------------------------------------------------------------------------
JINA_API_KEY=
FIRECRAWL_API_KEY=
SCRAPINGBEE_API_KEY=

# ---------------------------------------------------------------------------
# Billing (Razorpay Standard Checkout) — required for paid plans
# Get keys at https://dashboard.razorpay.com/app/keys
# KEY_ID is exposed to the browser; KEY_SECRET must stay server-side only.
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
