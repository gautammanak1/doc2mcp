# Copy this file to .env.local and fill in real values, or run `vercel env pull`.
# NEVER commit .env.local or real secrets.

# --- Core ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
POSTGRES_URL="postgres://user:pass@host:5432/db"

# Public base URL of this deployment. Leave empty on Vercel preview builds so
# the app falls back to the per-deployment VERCEL_URL (see CONTRIBUTING.md).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (Auth + storage) ---
# Scope these to Production, Preview AND Development in the Vercel dashboard,
# otherwise preview deployments cannot reach Supabase and login fails.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- AI provider (Google Gemini) ---
GEMINI_API_KEY="your-gemini-api-key"   # https://aistudio.google.com/apikey
# Optional model overrides (sensible defaults are used if unset)
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_IMAGE_MODEL="gemini-3-pro-image-preview"

# --- Admin access (comma-separated emails) ---
ADMIN_EMAILS="you@example.com"

# --- Optional: Upstash (caching / queue) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# QStash runs the conversion pipeline in its own worker so large docs finish
# within Vercel's lambda limit. Leave empty to fall back to inline processing.
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# --- Optional: Resend (contact form emails) ---
RESEND_API_KEY=""

# Local dev only: skip DB migrations on build.
SKIP_MIGRATE="1"
