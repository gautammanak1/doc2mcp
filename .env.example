# Copy this file to .env.local and fill in real values, or run `vercel env pull`.
# NEVER commit .env.local or real secrets.

# --- Core ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
POSTGRES_URL="postgres://user:pass@host:5432/db"

# Public base URL of this deployment. Leave empty on Vercel preview builds so
# the app falls back to the per-deployment VERCEL_URL (see CONTRIBUTING.md).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (Auth + storage) ---
# Scope these to Production, Preview AND Development in the Vercel dashboard,
# otherwise preview deployments cannot reach Supabase and login fails.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- AI provider ---
ASI_ONE_API_KEY="your-asi-one-key"

# --- Admin access (comma-separated emails) ---
ADMIN_EMAILS="you@example.com"

# --- Optional: Upstash (caching / queue) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_TOKEN=""

# --- Optional: Resend (contact form emails) ---
RESEND_API_KEY=""

# Local dev only: skip DB migrations on build.
SKIP_MIGRATE="1"
